    <!-- Tokens: border -->
    <string name="app_tokens_border_description_text">الحدود تستخدم لألوان الإطار على المكونات وكذلك لألوان خطوط الفواصل للمكونات مثل الجداول.</string>

    <!-- Tokens: color -->
    <string name="app_tokens_color_description_text">اللون يعزز هويتنا البصرية ويضمن التناسق عبر تجارب المنتجات.</string>
    <string name="app_tokens_color_unspecified_label">غير محدد</string>

    <!-- Tokens: dimension -->
    <string name="app_tokens_dimension_description_text"> توفر الأبعاد مقاسات وتباعدًا موحدًا لضمان الاتساق البصري في واجهة المستخدم.</string>

    <!-- Tokens: dimension/space -->
    <string name="app_tokens_dimension_space_description_text">المسافة تشير إلى القياسات المستخدمة لتعريف التباعد بين عناصر واجهة المستخدم.</string>
    <string name="app_tokens_dimension_space_scaledHeader_text">المسافة المقاسة المتغيرة تشير إلى التباعد الذي يتغير استنادًا إلى عوامل مثل حجم الحاوية، دقة الشاشة، أو عناصر التخطيط.</string>
    <string name="app_tokens_dimension_space_fixedHeader_text">تشير المسافات الثابتة إلى مسافة محددة بين العناصر التي تظل كما هي بغض النظر عن عوامل مثل حجم الحاوية، دقة الشاشة، أو تغييرات التخطيط.</string>
    <string name="app_tokens_dimension_space_paddingInlineHeader_text">الهوامش الجانبية تشمل المسافة بين الجوانب اليمنى واليسرى للعناصر.</string>
    <string name="app_tokens_dimension_space_paddingBlockHeader_text">تتضمن مساحة الحشو للكتلة الحشو من الأعلى والأسفل.</string>
    <string name="app_tokens_dimension_space_insetHeader_text">الهوامش الداخلية تتضمن الحشو من اليسار واليمين والأعلى والأسفل، مع جميع المعلمات متساوية.</string>
    <string name="app_tokens_dimension_space_columnGapHeader_text">الفاصل بين الأعمدة هو التباعد الأفقي بين العناصر.</string>
    <string name="app_tokens_dimension_space_rowGapHeader_text">الفاصل بين الصفوف هو التباعد العمودي بين العناصر.</string>

    <!-- Tokens: dimension/size -->
    <string name="app_tokens_dimension_size_description_text">يشير الحجم إلى القياسات المحددة التي تُستخدم لتعريف أبعاد عناصر واجهة المستخدم داخل نظام التصميم.</string>

    <!-- Tokens: elevation -->
    <string name="app_tokens_elevation_description_text">الظلال تستخدم لإعطاء انطباع بالمسافة أو الارتفاع بين الأسطح، مما يضيف عمقًا إلى تصميماتنا.</string>

    <!-- Tokens: grid -->
    <string name="app_tokens_grid_description_text">الشبكات تستخدم لوضع المحتوى وإنشاء تخطيطات الصفحة المتناسقة.</string>

    <!-- Tokens: opacity -->
    <string name="app_tokens_opacity_description_text">الشفافية يمكن أن تساعد في تمييز العناصر الأمامية عن الخلفية، مما يسهل قراءة المحتوى وجعل الإجراءات الهامة أكثر وضوحًا.</string>

    <!-- Tokens: typography -->
    <string name="app_tokens_typography_description_text">الطباعة هي نظامنا للخطوط وأنماط النصوص. إنها تعزز الاتصال وتدعم أسلوب العلامة التجارية.</string>

    <!-- Components -->
    <string name="app_components_common_textInputClearIcon_a11y">مسح المدخلات</string>
    <string name="app_components_common_error_a11y">الحد الأقصى للعرض</string>
    <string name="app_components_common_icon_a11y">أيقون</string>
    <string name="app_components_common_unreadNotificationsBadge_a11y">الإشعارات غير المقروءة</string>
    <plurals name="app_components_common_unreadMessageCountBadge_a11y">
        <item quantity="zero">لا توجد رسائل غير مقروءة</item>
        <item quantity="one">نص المساعدة</item>
        <item quantity="two">نص المساعدة</item>
        <item quantity="few">%d رسائل غير مقروءة</item>
        <item quantity="many">%d رسائل غير مقروءة</item>
    </plurals>
    <string name="app_components_common_version_label">نسخة تصميم المكون</string>

    <!-- Components: badge -->
    <string name="app_components_badge_description_text">Badge هي عنصر صغير في واجهة المستخدم يُستخدم لتسليط الضوء على الحالة أو الإشعارات أو التصنيف داخل الواجهة. غالبًا ما يتم عرضها كعلامة أو مؤشر بلون خلفية مميز ونص.</string>

    <!-- Components: button -->
    <string name="app_components_button_description_text">تسمح Buttons للمستخدمين باتخاذ قرارات أو تنفيذ إجراءات. وتتوفر بأنماط متعددة لتلبية احتياجات مختلفة.</string>

    <!-- Components: checkbox -->
    <string name="app_components_checkbox_description_text">تتيح Checkboxes للمستخدمين تحديد خيار واحد أو خيارات متعددة من القائمة، أو تشغيل الإعدادات أو إيقاف تشغيلها، أو تأكيد إجراء ما.</string>
    <string name="app_components_checkbox_checkbox_a11y">وصف محتوى مربع الاختيار %s</string>
    <string name="app_components_checkbox_indeterminateCheckbox_a11y">وصف محتوى مربع الاختيار غير المحدد %s</string>

    <!-- Components: chip -->
    <string name="app_components_chip_description_text">تساعد Chips   المستخدمين على إدخال المعلومات، القيام باختيارات، تصفية المحتوى، أو تنفيذ إجراءات.</string>

    <!-- Components: colored background -->
    <string name="app_components_coloredBackground_description_text">تستخدم Colored backgrounds ألوانًا محددة لتعزيز التباين مع المحتوى. يتكيف العديد من المكونات مثل الأزرار أو الروابط مع العرض وفقًا لذلك عند عرضها على خلفيات ملونة.</string>
    <string name="app_components_coloredBackground_unsupportedColor_text">السمة الحالية لا تدعم لون "%s".</string>

    <!-- Components: divider -->
    <string name="app_components_divider_description_text">ينظم Divider واجهة المستخدم بصريًا عن طريق فصل أقسام المحتوى بوضوح. يساعد على تحسين قابلية القراءة وتنظيم المحتوى دون إضافة تسلسل هرمي قوي كما في العناوين أو الحاويات.</string>

    <!-- Components: link -->
    <string name="app_components_link_description_text">تُستخدم Links لتوجيه المستخدمين إلى موارد أو أقسام إضافية، سواء كانت داخلية (ضمن نفس التطبيق) أو خارجية (مثل موقع إلكتروني أو مستند).</string>

    <!-- Components: navigation bar -->
    <string name="app_components_navigationBar_description_text">Navigation bars  يتيح للناس التبديل بين عروض واجهة المستخدم على الأجهزة الصغيرة</string> <!--TODO update with OUDS description-->
    <string name="app_components_navigationBar_homeItem_label">الصفحة الرئيسية</string>
    <string name="app_components_navigationBar_shopItem_label">المتجر</string>
    <string name="app_components_navigationBar_notificationsItem_label">الإشعارات</string>
    <string name="app_components_navigationBar_accountItem_label">الحساب</string>
    <string name="app_components_navigationBar_settingsItem_label">الإعدادات</string>

    <!-- Components: radio button -->
    <string name="app_components_radioButton_description_text">يُستخدم زر الاختيار لتمكين المستخدم من تحديد خيار واحد فقط من بين مجموعة خيارات حصرية. يُعرض عادةً كدائرة صغيرة مع تسمية، وتُملأ عند التحديد.</string>
    <string name="app_components_radioButton_radioButton_a11y">وصف محتوى زر الاختيار %s</string>

    <!-- Components: switch -->
    <string name="app_components_switch_description_text">يتيح Switch للمستخدم التبديل بين حالتين، عادةً تشغيل و إيقاف. يتم تمثيله غالبًا كزر أو شريط منزلق يتغير موقعه أو لونه للإشارة إلى الحالة الحالية. تُستخدم المفاتيح لتمكين أو تعطيل الميزات أو الخيارات أو الإعدادات بطريقة بصرية وفهمها بسهولة.</string>
    <string name="app_components_switch_switch_a11y">تبديل وصف المحتوى</string>

    <!-- Components: tag -->
    <string name="app_components_tag_description_text">Tag هو عنصر صغير يُستخدم لعرض معلومات قصيرة مثل تسمية أو كلمة مفتاحية أو تصنيف. يساعد المستخدمين على العثور على المحتوى بسرعة أو تجميعه أو فهمه.</string>

    <!-- Components: text input -->
    <string name="app_components_textInput_description_text">Text Input هو أحد مكونات واجهة المستخدم، ويُتيح للمستخدمين إدخال بيانات نصية أحادية السطر أو تحريرها أو تحديدها. وهو أحد أهم عناصر النموذج المستخدمة لتسجيل بيانات المستخدم، مثل الأسماء ورسائل البريد الإلكتروني وكلمات المرور واستعلامات البحث</string>
    <string name="app_components_textInput_trailingAction_a11y">وصف محتوى أيقونة النهاية</string>

    <!-- Components: top app bar -->
    <string name="app_components_topAppBar_description_text">ُعرض Top app bars المعلومات والإجراءات في أعلى الشاشة.</string> <!--TODO update with OUDS description-->
